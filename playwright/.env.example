# Ambiente: demo | staging | local (o custom con API_BASE_URL)
TEST_ENV=demo

# Modo debug HTTP: adjuntos .http.txt en el reporte HTML + logs en consola + trace on
# Valores: 1 activa, 0 u omitido desactiva (también acepta PW_HTTP_LOG=1)
DEBUG_API=0

# Opcional: fuerza la URL base (gana sobre TEST_ENV)
# API_BASE_URL=https://petstore.swagger.io/v2/
